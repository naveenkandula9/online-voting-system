NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Example:
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/online_voting_system?retryWrites=true&w=majority
MONGODB_URI=

# Comma-separated list of allowed frontend origins
# For development: http://localhost:5173,http://localhost:3000
# For production: https://your-vercel-app.vercel.app
CLIENT_ORIGIN=http://localhost:5173,http://localhost:3000

# JWT settings used in later auth steps
JWT_ACCESS_SECRET=replace_with_a_long_random_access_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=replace_with_a_long_random_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# Mock OTP settings used in later auth steps
OTP_TTL_MINUTES=5

# Gmail SMTP settings for vote confirmation emails
# Use a Gmail App Password, not your normal Gmail password.
EMAIL_USER=yourgmail@gmail.com
EMAIL_PASS=your_app_password

# Optional first admin seed account
ADMIN_NAME=Election Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PHONE=9999999999
ADMIN_AADHAAR=999999999999
ADMIN_STATE=National
ADMIN_PASSWORD=Admin@12345
